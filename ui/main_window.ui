  <property name="styleSheet">
   <string notr="true">/* =========================================
   ОБЩИЙ ФОН И ШРИФТЫ
   ========================================= */
QWidget {
    background-color: #2b2b2b;
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif;
    font-size: 10pt;
}

/* =========================================
   ГРУППЫ ПАРАМЕТРОВ (QGroupBox)
   ========================================= */
QGroupBox {
    border: 1px solid #555555;
    border-radius: 6px;
    margin-top: 1.2em; /* Отступ сверху, чтобы заголовок не наезжал на рамку */
    padding-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    color: #4da6ff; /* Инженерный синий акцент */
    font-weight: bold;
}

/* =========================================
   ПОЛЯ ВВОДА (SpinBoxes)
   ========================================= */
QSpinBox, QDoubleSpinBox {
    background-color: #3c3f41;
    border: 1px solid #555555;
    border-radius: 4px;
    padding: 4px;
    color: #ffffff;
    min-width: 60px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #4da6ff; /* Синяя подсветка при вводе с клавиатуры */
    background-color: #45494a;
}

/* Стилизация стрелочек вверх/вниз */
QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    background-color: #45494a;
    border-left: 1px solid #555555;
    width: 20px;
}

QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #54585a;
}

/* =========================================
   ТАБЛИЦА СОРТАМЕНТА (QTableWidget)
   ========================================= */
QTableWidget {
    background-color: #1e1e1e;
    alternate-background-color: #2a2d2e; /* Цвет для &quot;зебры&quot; (четные строки) */
    color: #e0e0e0;
    gridline-color: #3c3f41;
    border: 1px solid #555555;
    border-radius: 4px;
    outline: none; /* Убирает пунктирную рамку фокуса */
}

QTableWidget::item {
    padding: 4px;
}

QTableWidget::item:hover {
    background-color: #353839; /* Легкая подсветка при наведении */
}

QTableWidget::item:selected {
    background-color: #007ACC; /* Глубокий синий при выборе профиля */
    color: white;
    font-weight: bold;
}

/* Заголовки столбцов таблицы */
QHeaderView::section {
    background-color: #3c3f41;
    color: #ffffff;
    padding: 6px;
    border: 1px solid #555555;
    border-top: none;
    border-left: none;
    font-weight: bold;
    font-size: 9pt;
}

QHeaderView::section:hover {
    background-color: #54585a;
}

/* Квадратик в левом верхнем углу таблицы */
QTableCornerButton::section {
    background-color: #3c3f41;
    border: 1px solid #555555;
}

/* =========================================
   КНОПКИ (QPushButton)
   ========================================= */
QPushButton {
    background-color: #45494a;
    border: 1px solid #555555;
    border-radius: 4px;
    padding: 8px 15px;
    color: #e0e0e0;
}

QPushButton:hover {
    background-color: #54585a;
    border: 1px solid #777777;
}

QPushButton:pressed {
    background-color: #3c3f41;
}

/* Спец. стиль для кнопки &quot;Запустить&quot; */
QPushButton#btn_run {
    background-color: #2b7041; /* Спокойный зеленый */
    border: 1px solid #3d9e5a;
    color: white;
    font-size: 11pt;
}

QPushButton#btn_run:hover {
    background-color: #358c51;
}

QPushButton#btn_run:pressed {
    background-color: #1f5230;
}

/* Спец. стиль для кнопки &quot;Стоп&quot; */
QPushButton#btn_stop {
    background-color: #8c3d3d; /* Спокойный красный */
    border: 1px solid #a64d4d;
    color: white;
}

QPushButton#btn_stop:hover {
    background-color: #a64d4d;
}

QPushButton#btn_stop:pressed {
    background-color: #5c2828;
}

/* =========================================
   ШКАЛА ПРОГРЕССА (QProgressBar)
   ========================================= */
QProgressBar {
    border: 1px solid #555555;
    border-radius: 4px;
    text-align: center;
    background-color: #1e1e1e;
    color: white;
    font-weight: bold;
    min-height: 20px;
}

QProgressBar::chunk {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #007ACC, stop:1 #4da6ff);
    border-radius: 3px;
}

/* =========================================
   ТЕРМИНАЛ ЛОГОВ (QTextEdit)
   ========================================= */
QTextEdit#log_output {
    background-color: #121212; /* Черный фон как в настоящем терминале */
    color: #a9b7c6; /* Цвет текста как в IDE */
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace; /* Строго моноширинный шрифт */
    font-size: 10pt;
    border: 1px solid #555555;
    border-radius: 4px;
    padding: 8px;
}</string>
